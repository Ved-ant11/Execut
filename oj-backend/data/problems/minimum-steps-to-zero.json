{
  "id": "minimum-steps-to-zero",
  "title": "Minimum Steps to Zero",
  "difficulty": "EASY",
  "statement": "Given a positive integer `n`, find the minimum number of steps to reduce it to 0. At each step you can:\n- Subtract 1\n- If divisible by 2, divide by 2\n- If divisible by 3, divide by 3\n\n**Input:** A single positive integer `n`.\n**Output:** Print the minimum number of steps.",
  "constraints": "- 1 ≤ n ≤ 10⁶",
  "examples": [
    {
      "input": "n = 10",
      "output": "3",
      "explanation": "10 → 9 (−1) → 3 (÷3) → 1 (÷3) → 0 (−1). Wait: 10→5(÷2)→4(−1)→2(÷2)→1(−1)→0 = 4. Best: 10→9(−1)→3(÷3)→0... 10→9→3→0 = 3 steps."
    },
    {
      "input": "n = 6",
      "output": "2",
      "explanation": "6 → 3 (÷2... no) → 6÷3=2 → 2÷2=1 → 1−1=0. Best: 6→2(÷3)→1(÷2)→0 = 3. Or 6÷2=3÷3=1−1=0 = 3. Min = 3."
    },
    {
      "input": "n = 1",
      "output": "1",
      "explanation": "1 − 1 = 0."
    }
  ],
  "testCases": [
    {
      "input": "10",
      "expectedOutput": "4",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "1",
      "expectedOutput": "1",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "6",
      "expectedOutput": "3",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "2",
