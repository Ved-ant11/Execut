{
  "id": "climbing-stairs",
  "title": "Climbing Stairs",
  "difficulty": "EASY",
  "statement": "You are climbing a staircase. It takes `n` steps to reach the top.\n\nEach time you can either climb `1` or `2` steps. In how many distinct ways can you climb to the top?\n\n**Input:** A single integer `n`.\n**Output:** Print the number of distinct ways.",
  "constraints": "- 1 ≤ n ≤ 45",
  "examples": [
    {
      "input": "n = 2",
      "output": "2",
      "explanation": "Two ways: 1+1 or 2."
    },
    {
      "input": "n = 3",
      "output": "3",
      "explanation": "Three ways: 1+1+1, 1+2, 2+1."
    }
  ],
  "testCases": [
    {
      "input": "2",
      "expectedOutput": "2",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "3",
      "expectedOutput": "3",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1",
      "expectedOutput": "1",
      "order": 3,
      "isHidden": true
    },
    {
      "input": "4",
      "expectedOutput": "5",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "5",
      "expectedOutput": "8",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "10",
      "expectedOutput": "89",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "45",
      "expectedOutput": "1836311903",
      "order": 7,
      "isHidden": true
    }
  ],
  "tags": [
    "Dynamic Programming"
  ]
}
