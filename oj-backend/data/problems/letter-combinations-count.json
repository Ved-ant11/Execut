{
  "id": "letter-combinations-count",
  "title": "Letter Combinations of Phone Number — Count",
  "difficulty": "EASY",
  "statement": "A phone keypad maps digits 2-9 to letters. Given a digit string, find the total number of letter combinations possible.\n\nMapping: 2→ABC, 3→DEF, 4→GHI, 5→JKL, 6→MNO, 7→PQRS, 8→TUV, 9→WXYZ.\n\n**Input:** A digit string (digits 2-9 only).\n**Output:** Print the count. If empty, print `0`.",
  "constraints": "- 0 ≤ digits.length ≤ 10\n- digits[i] is between '2' and '9'.",
  "examples": [
    {
      "input": "23",
      "output": "9",
      "explanation": "2→3 letters, 3→3 letters. 3×3=9."
    },
    {
      "input": "2",
      "output": "3",
      "explanation": "A, B, or C."
    },
    {
      "input": "79",
      "output": "16",
      "explanation": "7→4 letters, 9→4 letters. 4×4=16."
    }
  ],
  "testCases": [
    {
      "input": "23",
      "expectedOutput": "9",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "2",
      "expectedOutput": "3",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "79",
      "expectedOutput": "16",
      "order": 3,
      "isHidden": false
    },
