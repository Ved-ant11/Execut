{
  "id": "trapping-rain-water",
  "title": "Trapping Rain Water",
  "difficulty": "HARD",
  "statement": "Given `n` non-negative integers representing an elevation map where the width of each bar is `1`, compute how much water it can trap after raining.\n\n**Input:** Space-separated non-negative integers representing the elevation map.\n**Output:** Print the total amount of trapped water.",
  "constraints": "- 1 ≤ n ≤ 2 × 10⁴\n- 0 ≤ height[i] ≤ 10⁵",
  "examples": [
    {
      "input": "height = [0,1,0,2,1,0,1,3,2,1,2,1]",
      "output": "6",
      "explanation": "The elevation map traps 6 units of rain water."
    },
    {
      "input": "height = [4,2,0,3,2,5]",
      "output": "9",
      "explanation": "The elevation map traps 9 units of rain water."
    }
  ],
  "testCases": [
    {
      "input": "0 1 0 2 1 0 1 3 2 1 2 1",
      "expectedOutput": "6",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "4 2 0 3 2 5",
      "expectedOutput": "9",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1 2 3 4 5",
      "expectedOutput": "0",
      "order": 3,
      "isHidden": true
    },
    {
      "input": "5 4 3 2 1",
      "expectedOutput": "0",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "3 0 3",
      "expectedOutput": "3",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "0",
      "expectedOutput": "0",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "5 2 1 2 1 5",
      "expectedOutput": "14",
      "order": 7,
      "isHidden": true
    }
  ],
