{
  "id": "max-frequency-after-k-ops",
  "title": "Maximum Frequency Element After K Operations",
  "difficulty": "MEDIUM",
  "statement": "Given an integer array `nums` and integer `k`, you can increment any element by 1 in each operation. Return the maximum frequency of any element after performing at most `k` operations.\n\n**Input:**\n- Line 1: space-separated integers.\n- Line 2: integer `k`.\n\n**Output:** Print the maximum achievable frequency.",
  "constraints": "- 1 \u2264 nums.length \u2264 10\u2075\n- 1 \u2264 nums[i] \u2264 10\u2075\n- 0 \u2264 k \u2264 10\u2075",
  "examples": [
    {
      "input": "nums=[1,2,4], k=5",
      "output": "3",
      "explanation": "Increment 1 by 3 and 2 by 2 to get [4,4,4]. Freq=3."
    },
    {
      "input": "nums=[1,4,8,13], k=5",
      "output": "2",
      "explanation": "Best is 2 of any value."
    },
    {
      "input": "nums=[1,1,1,2,2,4], k=2",
      "output": "4",
      "explanation": "Increment two 2s to 4, or increment to make four 2s."
    }
  ],
  "testCases": [
    {
      "input": "1 2 4\n5",
      "expectedOutput": "3",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "1 4 8 13\n5",
      "expectedOutput": "2",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1 1 1 2 2 4\n2",
      "expectedOutput": "4",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1\n0",
      "expectedOutput": "1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "3 9 6\n2",
      "expectedOutput": "1",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "1 2 3 4\n10",
      "expectedOutput": "4",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "5 5 5 5\n0",
      "expectedOutput": "4",
      "order": 7,
      "isHidden": true
    }
  ]
}