{
  "id": "string-compression-k",
  "title": "String Compression with K Removals",
  "difficulty": "MEDIUM",
  "statement": "Run-length encoding length: 1 char→1, 2-9→2, 10-99→3, 100-999→4. Given string `s` and integer `k`, delete at most `k` characters to **minimize the RLE length**.\n\n**Input:** First line: string s. Second line: k.\n**Output:** Minimum encoded length.",
  "constraints": "- 1 ≤ s.length ≤ 100\n- 0 ≤ k ≤ s.length",
  "examples": [
    {
      "input": "aaabcccd\n2",
      "output": "4",
      "explanation": "Delete 'b' and 'd' → 'aaaccc' → a3c3 = 4 chars."
    },
    {
      "input": "aabbaa\n2",
      "output": "2",
      "explanation": "Delete both 'b's → 'aaaa' → a4 = 2 chars."
    },
    {
      "input": "a\n1",
      "output": "0",
      "explanation": "Delete the only char. Empty string has length 0."
    }
  ],
  "testCases": [
    {
      "input": "aaabcccd\n2",
      "expectedOutput": "4",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "aabbaa\n2",
      "expectedOutput": "2",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "a\n1",
      "expectedOutput": "0",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "abc\n0",
      "expectedOutput": "3",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "aaaaaaaaaa\n0",
      "expectedOutput": "3",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "aaaaaaaaaa\n9",
      "expectedOutput": "1",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "aabbccddeeff\n4",
      "expectedOutput": "4",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "abcdefghijklmnopqrstuvwxyz\n26",
      "expectedOutput": "0",
      "order": 8,
      "isHidden": true
    }
  ],
  "tags": [
    "Strings",
    "Dynamic Programming"
  ]
}
