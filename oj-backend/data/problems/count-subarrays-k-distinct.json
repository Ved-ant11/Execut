{
  "id": "count-subarrays-k-distinct",
  "title": "Subarrays with Exactly K Distinct Values",
  "difficulty": "HARD",
  "statement": "Given an integer array `nums` and integer `k`, return the number of subarrays that contain exactly `k` distinct values.\n\n**Input:**\n- Line 1: space-separated integers.\n- Line 2: integer `k`.\n\n**Output:** Print the count.",
  "constraints": "- 1 \u2264 nums.length \u2264 2 \u00d7 10\u2074\n- 1 \u2264 nums[i] \u2264 nums.length\n- 1 \u2264 k \u2264 nums.length",
  "examples": [
    {
      "input": "nums=[1,2,1,2,3], k=2",
      "output": "7",
      "explanation": "7 subarrays have exactly 2 distinct values."
    },
    {
      "input": "nums=[1,2,1,3,4], k=3",
      "output": "3",
      "explanation": "3 subarrays have exactly 3 distinct values."
    },
    {
      "input": "nums=[1,1,1], k=1",
      "output": "6",
      "explanation": "All 6 subarrays have exactly 1 distinct value."
    }
  ],
  "testCases": [
    {
      "input": "1 2 1 2 3\n2",
      "expectedOutput": "7",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "1 2 1 3 4\n3",
      "expectedOutput": "3",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1 1 1\n1",
      "expectedOutput": "6",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1 2 3 4 5\n1",
      "expectedOutput": "5",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "2 1 1 1 2\n2",
      "expectedOutput": "7",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "1 2\n1",
      "expectedOutput": "2",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "1 2 3\n2",
      "expectedOutput": "2",
      "order": 7,
      "isHidden": true
    }
  ]
}