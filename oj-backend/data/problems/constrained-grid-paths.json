{
  "id": "constrained-grid-paths",
  "title": "Grid Paths with Turn Limit",
  "difficulty": "HARD",
  "statement": "Count the number of paths from the top-left to the bottom-right of an `n × m` grid, moving only right or down, with **at most `t` turns** (a turn is switching from moving right to moving down or vice versa). Return the answer mod 10⁹+7.\n\n**Input:** Single line: n m t.\n**Output:** Number of valid paths mod 10⁹+7.",
  "constraints": "- 1 ≤ n, m ≤ 100\n- 0 ≤ t ≤ n+m",
  "examples": [
    {
      "input": "2 2 1",
      "output": "2",
      "explanation": "Paths with ≤1 turn: RD (1 turn) and DR (1 turn). Total=2."
    },
    {
      "input": "2 2 2",
      "output": "2",
      "explanation": "Only 2 paths exist in a 2×2 grid regardless of turn limit."
    },
    {
      "input": "3 3 2",
      "output": "4",
      "explanation": "Paths needing ≤2 turns. RRD D, R DD R, etc. 4 valid paths."
    }
  ],
  "testCases": [
    {
      "input": "2 2 1",
      "expectedOutput": "2",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "2 2 2",
      "expectedOutput": "2",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "3 3 2",
      "expectedOutput": "4",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1 1 0",
      "expectedOutput": "1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "3 3 0",
      "expectedOutput": "0",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "3 3 4",
      "expectedOutput": "6",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "4 4 2",
      "expectedOutput": "6",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "5 5 3",
      "expectedOutput": "26",
      "order": 8,
      "isHidden": true
    }
  ],
  "tags": [
    "Dynamic Programming",
    "Matrix"
  ]
}
