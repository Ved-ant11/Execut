{
  "id": "matrix-chain-order",
  "title": "Matrix Chain Multiplication",
  "difficulty": "MEDIUM",
  "statement": "You need to multiply a chain of matrices. Matrix `i` has dimensions `dims[i-1] × dims[i]`. The cost of multiplying an `a×b` matrix by a `b×c` matrix is `a×b×c`. Find the **minimum total cost** to multiply all matrices in the chain.\n\n**Input:** Space-separated dimensions array (length = number of matrices + 1).\n**Output:** Minimum multiplication cost.",
  "constraints": "- 2 ≤ dims.length ≤ 500\n- 1 ≤ dims[i] ≤ 500",
  "examples": [
    {
      "input": "40 20 30 10 30",
      "output": "26000",
      "explanation": "Optimal parenthesization gives 26000 operations."
    },
    {
      "input": "10 30 5 60",
      "output": "4500",
      "explanation": "Multiply (A×B)×C: (10×30×5)+(10×5×60)=1500+3000=4500."
    },
    {
      "input": "1 2 3 4",
      "output": "18",
      "explanation": "Multiply (A×B)×C first: (1×2×3)+(1×3×4)=6+12=18."
    }
  ],
  "testCases": [
    {
      "input": "40 20 30 10 30",
      "expectedOutput": "26000",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "10 30 5 60",
      "expectedOutput": "4500",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1 2 3 4",
      "expectedOutput": "18",
      "order": 3,
      "isHidden": false
    },
    {
