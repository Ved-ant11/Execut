{
  "id": "min-cost-cut-stick",
  "title": "Minimum Cost to Cut a Stick",
  "difficulty": "HARD",
  "statement": "Given a stick of length `n` and an array `cuts` of positions to cut, find the minimum total cost. The cost of a cut is the length of the stick being cut. You can perform cuts in any order.\n\n**Input:**\n- Line 1: integer `n`.\n- Line 2: space-separated cut positions.\n\n**Output:** Print the minimum cost.",
  "constraints": "- 2 ≤ n ≤ 10⁶\n- 1 ≤ cuts.length ≤ min(n-1, 100)\n- All cut positions are unique, between 1 and n-1.",
  "examples": [
    {
      "input": "n=7, cuts=[1,3,4,5]",
      "output": "16",
      "explanation": "Optimal order gives total cost 16."
    },
    {
      "input": "n=9, cuts=[5,6,1,4,2]",
      "output": "22",
      "explanation": "Optimal order of cuts."
    },
    {
      "input": "n=5, cuts=[3]",
      "output": "5",
      "explanation": "One cut costs the full length = 5."
    }
  ],
  "testCases": [
    {
      "input": "7\n1 3 4 5",
      "expectedOutput": "16",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "9\n5 6 1 4 2",
      "expectedOutput": "22",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "5\n3",
      "expectedOutput": "5",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "10\n2 4 7",
      "expectedOutput": "20",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "6\n1 2 3 4 5",
      "expectedOutput": "14",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "100\n50",
      "expectedOutput": "100",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "10\n1 9",
      "expectedOutput": "20",
      "order": 7,
      "isHidden": true
    }
  ],
  "tags": [
    "Dynamic Programming"
  ]
}
