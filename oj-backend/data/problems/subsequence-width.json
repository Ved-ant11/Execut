{
  "id": "subsequence-width",
  "title": "Sum of Subsequence Widths",
  "difficulty": "HARD",
  "statement": "The **width** of a subsequence is the difference between its maximum and minimum element. Find the sum of widths of all non-empty subsequences of the array. Return the answer mod 10⁹+7.\n\n**Input:** First line: n. Second line: n space-separated integers.\n**Output:** Sum of widths mod 10⁹+7.",
  "constraints": "- 1 ≤ n ≤ 2×10⁵\n- 1 ≤ arr[i] ≤ 10⁵",
  "examples": [
    {
      "input": "2\n2 1",
      "output": "1",
      "explanation": "Subsequences: [2](width 0), [1](width 0), [2,1](width 1). Sum=1."
    },
    {
      "input": "3\n3 1 2",
      "output": "6",
      "explanation": "Sort: 1,2,3. All non-empty subsequences: single elements (width 0), pairs: (1,2)=1,(1,3)=2,(2,3)=1, triple (1,2,3)=2. Sum=0+0+0+1+2+1+2=6."
    },
    {
      "input": "1\n5",
      "output": "0",
      "explanation": "Only one element, only one subsequence of width 0."
    }
  ],
  "testCases": [
    {
      "input": "2\n2 1",
      "expectedOutput": "1",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "3\n3 1 2",
      "expectedOutput": "6",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1\n5",
      "expectedOutput": "0",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "3\n1 2 3",
      "expectedOutput": "6",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "4\n1 2 3 4",
      "expectedOutput": "23",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "2\n1 1",
      "expectedOutput": "0",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "5\n1 2 3 4 5",
      "expectedOutput": "72",
      "order": 7,
      "isHidden": true
    }
  ],
  "tags": [
    "Dynamic Programming",
