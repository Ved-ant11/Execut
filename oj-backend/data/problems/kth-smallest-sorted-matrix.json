{
  "id": "kth-smallest-sorted-matrix",
  "title": "Kth Smallest Element in Sorted Matrix",
  "difficulty": "HARD",
  "statement": "Given an `n x n` matrix where each row and column is sorted in ascending order, find the kth smallest element.\n\n**Input:**\n- Line 1: two integers `n` and `k`.\n- Next `n` lines: `n` space-separated integers per row.\n\n**Output:** Print the kth smallest element.",
  "constraints": "- 1 \u2264 n \u2264 300\n- -10\u2079 \u2264 matrix[i][j] \u2264 10\u2079\n- 1 \u2264 k \u2264 n\u00b2",
  "examples": [
    {
      "input": "n=3, k=8, matrix=[[1,5,9],[10,11,13],[12,13,15]]",
      "output": "13",
      "explanation": "Sorted: 1,5,9,10,11,12,13,13,15. 8th = 13."
    },
    {
      "input": "n=1, k=1, matrix=[[-5]]",
      "output": "-5",
      "explanation": "Only element."
    },
    {
      "input": "n=2, k=2, matrix=[[1,2],[1,3]]",
      "output": "1",
      "explanation": "Sorted: 1,1,2,3. 2nd = 1."
    }
  ],
  "testCases": [
    {
      "input": "3 8\n1 5 9\n10 11 13\n12 13 15",
      "expectedOutput": "13",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "1 1\n-5",
      "expectedOutput": "-5",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "2 2\n1 2\n1 3",
      "expectedOutput": "1",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "2 2\n1 2\n3 4",
      "expectedOutput": "2",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "3 5\n1 2 3\n4 5 6\n7 8 9",
      "expectedOutput": "5",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "3 1\n1 5 9\n10 11 13\n12 13 15",
      "expectedOutput": "1",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "3 9\n1 5 9\n10 11 13\n12 13 15",
      "expectedOutput": "15",
      "order": 7,
      "isHidden": true
    }
  ]
}