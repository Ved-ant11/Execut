{
  "id": "matrix-chain-multiplication",
  "title": "Matrix Chain Multiplication",
  "difficulty": "HARD",
  "statement": "Given dimensions of a sequence of matrices, find the minimum number of scalar multiplications needed to multiply them all.\n\nMatrix `i` has dimensions `dims[i] × dims[i+1]`.\n\n**Input:** Space-separated integers representing the dimension array.\n**Output:** Print the minimum number of multiplications.",
  "constraints": "- 2 ≤ dims.length ≤ 15\n- 1 ≤ dims[i] ≤ 100",
  "examples": [
    {
      "input": "dims=[10,30,5,60]",
      "output": "4500",
      "explanation": "(A×B)×C costs 10×30×5 + 10×5×60 = 4500."
    },
    {
      "input": "dims=[1,2,3,4]",
      "output": "18",
      "explanation": "Optimal order costs 18."
    },
    {
      "input": "dims=[40,20,30,10,30]",
      "output": "26000",
      "explanation": "Optimal parenthesization."
    }
  ],
  "testCases": [
    {
      "input": "10 30 5 60",
      "expectedOutput": "4500",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "1 2 3 4",
      "expectedOutput": "18",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "40 20 30 10 30",
      "expectedOutput": "26000",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "2 3",
      "expectedOutput": "0",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "10 20 30",
      "expectedOutput": "6000",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "5 10 3 12 5 50 6",
      "expectedOutput": "2010",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "1 2 3",
      "expectedOutput": "6",
      "order": 7,
      "isHidden": true
    }
  ],
  "tags": [
    "Dynamic Programming"
  ]
}
