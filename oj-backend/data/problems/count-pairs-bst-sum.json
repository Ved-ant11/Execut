{
  "id": "count-pairs-bst-sum",
  "title": "Count Pairs with Given Sum in BST",
  "difficulty": "MEDIUM",
  "statement": "Given the inorder traversal of a BST (a sorted array) and a target sum `k`, count the number of pairs `(i, j)` where `i < j` and `arr[i] + arr[j] == k`.\n\n**Input:**\n- Line 1: space-separated integers (sorted BST inorder).\n- Line 2: integer `k`.\n\n**Output:** Print the count of pairs.",
  "constraints": "- 1 \u2264 arr.length \u2264 10\u2075\n- -10\u2074 \u2264 arr[i] \u2264 10\u2074\n- All elements are distinct.",
  "examples": [
    {
      "input": "arr=[1,2,3,4,5,6,7], k=9",
      "output": "3",
      "explanation": "Pairs: (2,7),(3,6),(4,5)."
    },
    {
      "input": "arr=[1,3,5,7], k=8",
      "output": "2",
      "explanation": "Pairs: (1,7),(3,5)."
    },
    {
      "input": "arr=[1,2,3], k=10",
      "output": "0",
      "explanation": "No pairs sum to 10."
    }
  ],
  "testCases": [
    {
      "input": "1 2 3 4 5 6 7\n9",
      "expectedOutput": "3",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "1 3 5 7\n8",
      "expectedOutput": "2",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1 2 3\n10",
      "expectedOutput": "0",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1 5 7 8 10\n15",
      "expectedOutput": "2",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "-3 -1 0 1 3\n0",
      "expectedOutput": "2",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "1 2\n3",
      "expectedOutput": "1",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "1 2 3 4 5\n6",
      "expectedOutput": "2",
      "order": 7,
      "isHidden": true
    }
  ]
}