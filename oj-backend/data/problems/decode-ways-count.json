{
  "id": "decode-ways-count",
  "title": "Decode Ways Count",
  "difficulty": "HARD",
  "statement": "A string of digits can be decoded where:\n- `'1'` → `A`, `'2'` → `B`, ..., `'26'` → `Z`.\n\nGiven a string `s` containing only digits, return the **number of ways** to decode it.\n\nThe answer may be large but fits in a 64-bit integer.\n\n**Input:** A single string of digits.\n**Output:** Print the number of ways to decode it.",
  "constraints": "- 1 ≤ s.length ≤ 100\n- s contains only digits.\n- s may contain leading zeros.",
  "examples": [
    {
      "input": "s = \"12\"",
      "output": "2",
      "explanation": "'12' → 'AB' or 'L'. 2 ways."
    },
    {
      "input": "s = \"226\"",
      "output": "3",
      "explanation": "'226' → 'BZ', 'VF', 'BBF'. 3 ways."
    },
    {
      "input": "s = \"06\"",
      "output": "0",
      "explanation": "Leading zero — 0 can't map to anything."
    }
  ],
  "testCases": [
    {
      "input": "12",
      "expectedOutput": "2",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "226",
      "expectedOutput": "3",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "06",
      "expectedOutput": "0",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1",
      "expectedOutput": "1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "0",
      "expectedOutput": "0",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "11106",
      "expectedOutput": "2",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "111111111111",
      "expectedOutput": "233",
      "order": 7,
      "isHidden": true
    }
  ],
  "tags": [
    "Dynamic Programming",
    "Strings"
  ]
}
