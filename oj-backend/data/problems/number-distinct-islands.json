{
  "id": "number-distinct-islands",
  "title": "Number of Distinct Islands",
  "difficulty": "HARD",
  "statement": "Given a binary grid, count the number of **distinct** islands. Two islands are the same if one can be translated (not rotated/reflected) to match the other.\n\n**Input:**\n- Line 1: two integers `m` and `n`.\n- Next `m` lines: a string of `n` characters (`0` or `1`) per row.\n\n**Output:** Print the number of distinct island shapes.",
  "constraints": "- 1 ≤ m, n ≤ 50\n- grid[i][j] is 0 or 1.",
  "examples": [
    {
      "input": "m=4,n=5, grid shown",
      "output": "1",
      "explanation": "Both 2x2 islands have the same shape."
    },
    {
      "input": "m=4,n=5, grid shown",
      "output": "3",
      "explanation": "Three different island shapes."
    }
  ],
  "testCases": [
    {
      "input": "4 5\n11000\n11000\n00011\n00011",
      "expectedOutput": "1",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "4 5\n11011\n10000\n00001\n11011",
      "expectedOutput": "3",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "2 2\n11\n11",
      "expectedOutput": "1",
      "order": 3,
      "isHidden": true
    },
    {
      "input": "3 3\n100\n010\n001",
      "expectedOutput": "1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "1 5\n10101",
      "expectedOutput": "1",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "3 3\n110\n001\n011",
      "expectedOutput": "2",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "2 4\n1010\n0101",
      "expectedOutput": "1",
      "order": 7,
      "isHidden": true
    }
  ],
  "tags": [
    "Graphs",
    "DFS",
    "Matrix"
  ]
}
