{
  "id": "median-from-data-stream",
  "title": "Median from Data Stream",
  "difficulty": "HARD",
  "statement": "Given a stream of integers, after each insertion print the current median. If even count, print the average of two middle elements with one decimal place. If odd count, print the middle element as integer.\n\n**Input:** Space-separated integers (stream order).\n**Output:** Space-separated median after each insertion.",
  "constraints": "- 1 ≤ nums.length ≤ 10⁴\n- -10⁵ ≤ nums[i] ≤ 10⁵",
  "examples": [
    {
      "input": "nums=[5,3,8,4]",
      "output": "5 4 5 4.5",
      "explanation": "After 5:median=5. After 3:median=(3+5)/2=4. After 8:median=5. After 4:median=(4+5)/2=4.5."
    },
    {
      "input": "nums=[1,2]",
      "output": "1 1.5",
      "explanation": "After 1:1. After 2:(1+2)/2=1.5."
    },
    {
      "input": "nums=[3,1,2]",
      "output": "3 2 2",
      "explanation": "After 3:3. After 1:(1+3)/2=2. After 2:2."
    }
  ],
  "testCases": [
    {
      "input": "5 3 8 4",
      "expectedOutput": "5 4 5 4.5",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "1 2",
      "expectedOutput": "1 1.5",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "3 1 2",
      "expectedOutput": "3 2 2",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "6 5 4",
      "expectedOutput": "6 5.5 5",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "1",
      "expectedOutput": "1",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "2 1 3",
      "expectedOutput": "2 1.5 2",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "10 5 15 1",
      "expectedOutput": "10 7.5 10 7.5",
      "order": 7,
      "isHidden": true
    }
  ],
  "tags": [
    "Heap"
  ]
}
