{
  "id": "coin-change-minimum",
  "title": "Coin Change — Minimum Coins",
  "difficulty": "MEDIUM",
  "statement": "Given coin denominations and an amount, find the minimum number of coins needed to make the amount. Return `-1` if impossible.\n\n**Input:**\n- Line 1: space-separated coin denominations.\n- Line 2: integer `amount`.\n\n**Output:** Print the minimum coins or `-1`.",
  "constraints": "- 1 ≤ coins.length ≤ 12\n- 1 ≤ coins[i] ≤ 2³¹ - 1\n- 0 ≤ amount ≤ 10⁴",
  "examples": [
    {
      "input": "coins=[1,5,6,9], amount=11",
      "output": "2",
      "explanation": "5+6=11 or 2+9=11. Min=2."
    },
    {
      "input": "coins=[2], amount=3",
      "output": "-1",
      "explanation": "Cannot make 3 with only 2s."
    },
    {
      "input": "coins=[1,2,5], amount=11",
      "output": "3",
      "explanation": "5+5+1=11."
    }
  ],
  "testCases": [
    {
      "input": "1 5 6 9\n11",
      "expectedOutput": "2",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "2\n3",
      "expectedOutput": "-1",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1 2 5\n11",
      "expectedOutput": "3",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1\n0",
      "expectedOutput": "0",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "1 5 6 9\n0",
      "expectedOutput": "0",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "3 5\n11",
      "expectedOutput": "3",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "186 419 83 408\n6249",
      "expectedOutput": "20",
      "order": 7,
      "isHidden": true
    }
  ],
  "tags": [
    "Dynamic Programming"
  ]
}
