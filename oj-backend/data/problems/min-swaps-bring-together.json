{
  "id": "min-swaps-bring-together",
  "title": "Minimum Swaps to Bring Elements ≤ K Together",
  "difficulty": "MEDIUM",
  "statement": "Given an array `arr` and integer `k`, find the minimum number of swaps needed to bring all elements ≤ k together (in any contiguous window).\n\n**Input:**\n- Line 1: space-separated integers.\n- Line 2: integer `k`.\n\n**Output:** Print the minimum swaps.",
  "constraints": "- 1 ≤ arr.length ≤ 10⁵\n- 1 ≤ arr[i] ≤ 10⁷\n- 1 ≤ k ≤ max(arr)",
  "examples": [
    {
      "input": "arr=[2,1,5,6,3], k=3",
      "output": "1",
      "explanation": "Elements ≤3: positions 0,1,4. Need 1 swap to bring together."
    },
    {
      "input": "arr=[2,7,9,5,8,7,4], k=6",
      "output": "2",
      "explanation": "Elements ≤6: 2,5,4 at positions 0,3,6. Need 2 swaps."
    }
  ],
  "testCases": [
    {
      "input": "2 1 5 6 3\n3",
      "expectedOutput": "1",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "2 7 9 5 8 7 4\n6",
      "expectedOutput": "2",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1 2 3 4 5\n5",
      "expectedOutput": "0",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1 6 2 3 5 4\n4",
      "expectedOutput": "1",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "5 5 5 5\n5",
      "expectedOutput": "0",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "1 10 1 10 1\n1",
      "expectedOutput": "1",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "3 1 4 1 5 9 2 6\n4",
      "expectedOutput": "2",
      "order": 7,
      "isHidden": true
    }
  ],
  "tags": [
    "Sliding Window",
    "Arrays"
  ]
}
