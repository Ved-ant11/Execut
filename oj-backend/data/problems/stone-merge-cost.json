{
  "id": "stone-merge-cost",
  "title": "Stone Merge Minimum Cost",
  "difficulty": "HARD",
  "statement": "You have `n` piles of stones. In one operation merge any `k` consecutive piles into one; cost = sum of those k piles. Find the **minimum total cost** to merge all into one, or `-1` if impossible.\n\nNote: possible only if `(n-1) % (k-1) == 0`.\n\n**Input:** First line: space-separated pile sizes. Second line: k.\n**Output:** Minimum cost or -1.",
  "constraints": "- 2 ≤ n ≤ 30\n- 2 ≤ k ≤ n\n- 1 ≤ piles[i] ≤ 100",
  "examples": [
    {
      "input": "3 2 4 1\n2",
      "output": "20",
      "explanation": "Merge (3,2)→5 cost 5; (4,1)→5 cost 5; (5,5)→10 cost 10. Total=20."
    },
    {
      "input": "1 2 3\n3",
      "output": "6",
      "explanation": "Merge all 3 in one step: cost=6."
    },
    {
      "input": "1 2 3 4\n3",
      "output": "-1",
      "explanation": "(4-1)%(3-1)=1≠0. Impossible."
    }
  ],
  "testCases": [
    {
      "input": "3 2 4 1\n2",
      "expectedOutput": "20",
      "order": 1,
      "isHidden": false
    },
    {
      "input": "1 2 3\n3",
      "expectedOutput": "6",
      "order": 2,
      "isHidden": false
    },
    {
      "input": "1 2 3 4\n3",
      "expectedOutput": "-1",
      "order": 3,
      "isHidden": false
    },
    {
      "input": "1 2 3\n2",
      "expectedOutput": "9",
      "order": 4,
      "isHidden": true
    },
    {
      "input": "1 2 3 4 5\n5",
      "expectedOutput": "15",
      "order": 5,
      "isHidden": true
    },
    {
      "input": "1 1 1 1\n2",
      "expectedOutput": "8",
      "order": 6,
      "isHidden": true
    },
    {
      "input": "10 20 30 40\n2",
      "expectedOutput": "190",
      "order": 7,
      "isHidden": true
    },
    {
      "input": "5 3 2 7 1\n2",
      "expectedOutput": "41",
      "order": 8,
      "isHidden": true
    }
  ],
  "tags": [
    "Dynamic Programming"
  ]
}
